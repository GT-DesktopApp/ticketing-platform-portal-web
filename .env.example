# ─────────────────────────────────────────────────────────────────────────────
# Ticketing Platform Admin — Environment Variables
#
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# All variables are validated at startup by `src/config/env.ts` (Zod). A missing
# or malformed value fails the build/boot fast with a clear error.
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string.
# Use the POOLED connection string for the app (serverless-friendly).
# Example: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=YOUR_NEON_POOLED_CONNECTION_STRING

# Canonical URL of this deployment. Used by Auth.js for callbacks.
# Local development:
NEXTAUTH_URL=YOUR_LOCALHOST_URL  // localhost:3000
# Secret used to sign/encrypt Auth.js JWTs & cookies.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_AUTH_SECRET

# Node environment: development | test | production
NODE_ENV=development

# Optional: public app URL exposed to the browser (defaults to NEXTAUTH_URL usage).
# NEXT_PUBLIC_APP_URL=http://localhost:3000
