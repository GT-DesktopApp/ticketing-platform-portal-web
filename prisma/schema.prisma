// ─────────────────────────────────────────────────────────────────────────────
// Ticketing Platform Admin — Prisma Schema
//
// Database: Neon PostgreSQL
// Conventions:
//   • UUID primary keys everywhere (`@id @default(uuid()) @db.Uuid`).
//   • Every table carries `createdAt` and `updatedAt` audit timestamps.
//   • Join tables are explicit models (RolePermission, UserRole) so we can
//     attach metadata (who assigned, when) — a hard requirement for auditable
//     enterprise RBAC.
//   • snake_case table names via `@@map` for clean SQL; camelCase in code.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & Access (RBAC core)
// ─────────────────────────────────────────────────────────────────────────────

/// Application user. `passwordHash` is nullable to support OAuth-only accounts
/// in the future; credentials login populates it.
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  /// Optional login alias. Unique when present; login accepts email OR username.
  username     String?   @unique
  name         String?
  /// Contact mobile number (E.164 or local). Not used for login.
  mobile       String?
  passwordHash String?   @map("password_hash")
  image        String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")

  // Optional default branch/location scoping for multi-branch operations.
  branchId   String? @map("branch_id") @db.Uuid
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  locationId String? @map("location_id") @db.Uuid
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Relations
  userRoles UserRole[]
  auditLogs AuditLog[]
  accounts  Account[]
  sessions  Session[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([branchId])
  @@index([locationId])
  @@map("users")
}

/// A named role. System roles (Super Admin, Admin, …) are seeded with
/// `isSystem = true` and protected from deletion/renaming in the UI.
model Role {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique // machine key, e.g. "super_admin"
  name        String // display name, e.g. "Super Admin"
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  /// Inactive roles can't be assigned to new users and are flagged in the UI.
  isActive    Boolean @default(true) @map("is_active")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

/// A single permission, e.g. "tickets.create". `key` follows `<resource>.<action>`.
model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  description String?
  /// Logical grouping for the permission-picker UI, e.g. "Tickets".
  group       String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

/// Explicit Role↔Permission join. Carries assignment metadata for auditing.
model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedById String?   @map("assigned_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Explicit User↔Role join. A user may hold multiple roles.
model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedById String?  @map("assigned_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auditing
// ─────────────────────────────────────────────────────────────────────────────

/// Append-only audit trail. `actorId` is nullable so system/automated events
/// can be recorded. `metadata` holds a JSON snapshot of the change for forensics.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String // e.g. "user.created", "ticket.printed"
  entityType String?  @map("entity_type") // e.g. "User", "Ticket"
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Multi-branch / multi-location scaffolding
// (Models exist now so foreign keys are stable; full features come later.)
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  code     String  @unique
  isActive Boolean @default(true) @map("is_active")

  users     User[]
  locations Location[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("branches")
}

model Location {
  id       String  @id @default(uuid()) @db.Uuid
  branchId String  @map("branch_id") @db.Uuid
  name     String
  isActive Boolean @default(true) @map("is_active")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users  User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([branchId])
  @@map("locations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth.js (NextAuth) adapter models
// Required by @auth/prisma-adapter for OAuth/email flows added later.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS — Ticket Booking domain
//
// Models the booking flow seen in the designs:
//   Attraction → choose Visitor Categories & quantities → Customer →
//   (optional) sequential Seat allocation by Bogie → Payment.
// Money is stored in PAISE (integer) to avoid floating-point rounding in sales.
// ─────────────────────────────────────────────────────────────────────────────

/// A bookable attraction (ride / fort / palace / zoo …). The "Toy Train" card
/// in the booking screen is one of these. `requiresSeats` drives whether the
/// seat-allocation step is shown.
model Attraction {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  type        String // "Ride" | "Fort" | "Palace" | "Zoo" | "Museum" | "Heritage"
  /// Booking flow: STANDARD shows fixed visitor categories (Adult/Child/…);
  /// CATEGORY shows the attraction's own ticket categories from the DB.
  bookingType BookingType @default(STANDARD) @map("booking_type")
  description String?
  imageUrl    String? @map("image_url")

  /// Base rate per person in paise (e.g. ₹80 = 8000). Display-level info; the
  /// authoritative per-ticket price comes from TicketCategory.
  baseRatePaise Int  @map("base_rate_paise")
  durationMin   Int? @map("duration_min") // e.g. 20 (min per trip)

  /// Seats available per trip (e.g. 24). Null for non-seated attractions.
  seatsPerTrip  Int?    @map("seats_per_trip")
  requiresSeats Boolean @default(false) @map("requires_seats")

  /// The reusable seat layout attached to this attraction (when requiresSeats).
  seatLayoutId String?     @map("seat_layout_id") @db.Uuid
  seatLayout   SeatLayout? @relation(fields: [seatLayoutId], references: [id], onDelete: SetNull)

  openTime  String? @map("open_time") // "10:00 AM"
  closeTime String? @map("close_time") // "6:00 PM"
  isActive  Boolean @default(true) @map("is_active")

  categories TicketCategory[]
  bogies     Bogie[]
  bookings   Booking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([isActive])
  @@map("attractions")
}

/// A priced visitor category for an attraction (Adult, Child, Senior Citizen,
/// Student, Foreigner). Price is per-ticket, in paise.
/// A priced ticket row of an attraction. In STANDARD mode these are visitor
/// categories (Adult/Child/Foreigner/…); in CATEGORY mode they are the
/// attraction's own ticket categories (e.g. "Indian Adult (2-way)", "Boat (4)").
/// Both render in the SAME vertical row list (name / price / −qty+ / amount).
/// Table name kept as `ticket_categories` for FK stability.
model TicketCategory {
  id             String  @id @default(uuid()) @db.Uuid
  attractionId   String  @map("attraction_id") @db.Uuid
  /// Optional grouping type (CATEGORY mode), e.g. "Toy Train (VIP)".
  categoryTypeId String? @map("category_type_id") @db.Uuid
  name           String // e.g. "Adult" or "Indian Adult (2-way)"
  pricePaise     Int     @map("price_paise")
  /// Free-form note shown under the name, e.g. "ID Required".
  note           String?
  /// Optional image URL (CATEGORY tickets); null is fine.
  image          String?
  /// Legacy free-text grouping label; superseded by categoryType.
  category       String?
  /// HSN/SAC code for the receipt (e.g. "996411").
  sacCode        String? @map("sac_code")
  /// Barcode for scanning at the counter.
  barcode        String?
  /// GST rate as a percentage (stored per row; billing applies 18% flat).
  gstRate        Int     @default(18) @map("gst_rate")
  /// Scheduled next price (in paise). When set with `effectiveFrom`, this price
  /// takes over from `pricePaise` on/after that date. Null = no scheduled change.
  futurePricePaise Int?      @map("future_price_paise")
  /// Date from which `futurePricePaise` applies (inclusive). Null = not scheduled.
  effectiveFrom    DateTime? @map("effective_from") @db.Date
  sortOrder      Int     @default(0) @map("sort_order")
  isActive       Boolean @default(true) @map("is_active")

  attraction   Attraction    @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  categoryType CategoryType? @relation(fields: [categoryTypeId], references: [id], onDelete: SetNull)
  bookingItems BookingItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([attractionId])
  @@index([categoryTypeId])
  @@map("ticket_categories")
}

/// A category type used to group ticket categories in CATEGORY-mode attractions
/// (e.g. "Toy Train (VIP)", "Toy Train (Regular)", "Boat"). Loaded dynamically
/// for the New Category dialog's "Category Type" dropdown.
model CategoryType {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique
  isActive  Boolean @default(true) @map("is_active")

  ticketCategories TicketCategory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("category_types")
}

enum BookingType {
  STANDARD
  CATEGORY

  @@map("booking_type")
}

/// A registered customer, searchable by name or mobile in the Customer step.
model Customer {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  mobile    String  @unique
  email     String?
  /// GST identification number, shown in the Selected Customer Details block.
  gstn      String?
  /// Free-text address / notes for the customer record.
  notes     String?
  isActive  Boolean @default(true) @map("is_active")

  bookings Booking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("customers")
}

/// A bogie/coach of a seated attraction. Bogies open SEQUENTIALLY: only the
/// active bogie is selectable; later ones are `Locked` until the prior fills.
model Bogie {
  id           String      @id @default(uuid()) @db.Uuid
  attractionId String      @map("attraction_id") @db.Uuid
  label        String // "A" | "B" | "C"
  capacity     Int // e.g. 24
  /// Position in the sequential opening order (A=0, B=1, C=2).
  sequence     Int
  status       BogieStatus @default(LOCKED)

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  seats      Seat[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([attractionId, label])
  @@index([attractionId, sequence])
  @@map("bogies")
}

/// A single seat in a bogie. `status` is OCCUPIED once assigned to a booking.
model Seat {
  id      String     @id @default(uuid()) @db.Uuid
  bogieId String     @map("bogie_id") @db.Uuid
  number  Int // 1..capacity
  /// "left" | "right" — the two columns shown in the seat grid.
  side    String
  status  SeatStatus @default(AVAILABLE)

  bogie       Bogie            @relation(fields: [bogieId], references: [id], onDelete: Cascade)
  assignments SeatAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([bogieId, number])
  @@index([status])
  @@map("seats")
}

/// A reusable SEAT LAYOUT template (Layout Management + the attraction Seat
/// Allocation step). It captures the grid geometry — rows, left/right column
/// counts, aisle position/width — plus VIP rows and a display `totalSeats`. One
/// layout can be shared across many attractions (Attraction.seatLayoutId).
/// Presets (e.g. "3 × 36") seed `isCustom = false`; user grids from the Custom
/// Layout modal are stored with `isCustom = true` and appear in the dropdown.
model SeatLayout {
  id            String        @id @default(uuid()) @db.Uuid
  name          String // "Coach A", "3 × 36", …
  /// Total seats shown/allocated for this layout.
  totalSeats    Int           @map("total_seats")
  rows          Int
  columnsLeft   Int           @map("columns_left")
  columnsRight  Int           @map("columns_right")
  aislePosition AislePosition @default(CENTRE) @map("aisle_position")
  aisleWidth    AisleWidth    @default(MEDIUM) @map("aisle_width")
  /// 1-indexed row numbers marked VIP (JSON array of ints), e.g. [1, 2].
  vipRows       Json?         @map("vip_rows")
  /// True for user-created grids (Custom Layout); false for built-in presets.
  isCustom      Boolean       @default(true) @map("is_custom")
  isActive      Boolean       @default(true) @map("is_active")

  attractions Attraction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("seat_layouts")
}

/// A completed (or in-progress) booking — the unit a payment settles.
/// Amounts are in paise. `bookingNo` is a human-friendly receipt number.
model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  bookingNo    String        @unique @map("booking_no")
  attractionId String        @map("attraction_id") @db.Uuid
  customerId   String?       @map("customer_id") @db.Uuid
  status       BookingStatus @default(PENDING)

  /// True for complimentary passes — payment is waived; pass details captured.
  isComplimentary Boolean @map("is_complimentary") @default(false)
  passReference   String? @map("pass_reference")

  // --- Complimentary pass details (all null for a standard booking) ---
  passNo             String? @map("pass_no")
  passDate           String? @map("pass_date") // "YYYY-MM-DD"
  discountPercent    Int?    @map("discount_percent")
  guestName          String? @map("guest_name")
  guestMobile        String? @map("guest_mobile")
  guestDepartment    String? @map("guest_department")
  guestDesignation   String? @map("guest_designation")
  compAdultCount     Int?    @map("comp_adult_count")
  compChildCount     Int?    @map("comp_child_count")
  referenceName      String? @map("reference_name")
  referenceMobile    String? @map("reference_mobile")
  referenceDepartment  String? @map("reference_department")
  referenceDesignation String? @map("reference_designation")

  subtotalPaise Int @map("subtotal_paise")
  taxPaise      Int @default(0) @map("tax_paise")
  roundOffPaise Int @default(0) @map("round_off_paise")
  totalPaise    Int @map("total_paise")

  /// Who rang up the sale (staff user).
  createdById String? @map("created_by_id") @db.Uuid

  attraction      Attraction       @relation(fields: [attractionId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           BookingItem[]
  seatAssignments SeatAssignment[]
  payment         Payment?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([attractionId])
  @@index([customerId])
  @@index([status])
  @@map("bookings")
}

/// One line of a booking: a category × quantity at the price captured at sale
/// time (so historical bookings are unaffected by later price changes).
model BookingItem {
  id               String @id @default(uuid()) @db.Uuid
  bookingId        String @map("booking_id") @db.Uuid
  ticketCategoryId String @map("ticket_category_id") @db.Uuid
  categoryName     String @map("category_name") // snapshot for receipts
  quantity         Int
  unitPricePaise   Int    @map("unit_price_paise")
  lineTotalPaise   Int    @map("line_total_paise")

  booking  Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  category TicketCategory @relation(fields: [ticketCategoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bookingId])
  @@map("booking_items")
}

/// Binds a passenger (by category label) to a specific seat for a booking.
model SeatAssignment {
  id           String @id @default(uuid()) @db.Uuid
  bookingId    String @map("booking_id") @db.Uuid
  seatId       String @map("seat_id") @db.Uuid
  /// Passenger label shown in the UI, e.g. "Adult 1", "Child 1".
  passengerRef String @map("passenger_ref")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat    Seat    @relation(fields: [seatId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // A seat can only be assigned once (enforces no double-booking of a seat).
  @@unique([seatId])
  @@index([bookingId])
  @@map("seat_assignments")
}

/// The payment that settles a booking. One per booking (1–1).
model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  bookingId      String        @unique @map("booking_id") @db.Uuid
  method         PaymentMethod
  amountDuePaise Int           @map("amount_due_paise")
  amountPaidPaise Int          @map("amount_paid_paise")
  changePaise    Int           @default(0) @map("change_paise")
  status         PaymentStatus @default(COMPLETED)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

enum BogieStatus {
  ACTIVE
  LOCKED
  FULL

  @@map("bogie_status")
}

/// Where the aisle sits in a seat layout (Custom Layout modal).
enum AislePosition {
  LEFT
  CENTRE
  RIGHT
  DUAL
  NONE

  @@map("aisle_position")
}

/// The relative width of the aisle gap in a seat layout.
enum AisleWidth {
  NARROW
  MEDIUM
  WIDE

  @@map("aisle_width")
}

enum SeatStatus {
  AVAILABLE
  OCCUPIED
  BLOCKED

  @@map("seat_status")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED

  @@map("booking_status")
}

enum PaymentMethod {
  CASH
  CARD
  UPI

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@map("payment_status")
}
